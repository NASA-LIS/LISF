######################################
# JUPYTER
######################################

.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# If you DON'T want notebooks tracked:
# *.ipynb

# If you want to track notebooks but ignore output:
# (Use nbstripout instead — recommended for research workflows)


######################################
# PYTHON
######################################

__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.env
.venv
venv/
ENV/
env/

# Pip logs
pip-log.txt
pip-delete-this-directory.txt

# pytest
.pytest_cache/
.coverage
htmlcov/

# mypy
.mypy_cache/

# IDE
.vscode/
.idea/


######################################
# FORTRAN
######################################

# Compiled objects
*.o
*.obj
*.mod
*.smod

# Static and shared libraries
*.a
*.so
*.dylib

# Executables
*.exe
*.out

# Intel Fortran
*.optrpt
*.ipo
*.il

# gfortran dumps
*.dump


######################################
# SLURM / HPC
######################################

slurm-*.out
*.sbatch
*.log


######################################
# DATA FILES (optional — customize!)
######################################

# Large scientific files
*.nc
*.hdf
*.h5
*.tif
*.grb

# Temporary outputs
tmp/
output/
results/


######################################
