[runtime]
    [[root]]
        platform = slurm-ghi
        pre-script = """
            source /etc/profile.d/modules.sh
            module load lisf_7.5_intel_2023.2.1_s2s
        """
        [[[environment]]]
            USE_CYLC_ENV = 1
            MODULEPATH = /discover/nobackup/projects/usaf_lis/smahanam/S2S/LISF-1/env/discover/:$MODULEPATH
            PYTHONPATH = /discover/nobackup/projects/usaf_lis/smahanam/S2S/LISF-1/lis/utils/usaf/S2S/
        [[[mail]]]
            to = sarith.p.mahanama@nasa.gov
        [[[events]]]
            mail events = failed
  
    [[log_monitor]]
        script = /discover/nobackup/projects/ghilis/smahanam/PR79_E2E/scratch/202601/ghis2s_log.sh
        platform = localhost-ghi
  
    [[final_log_collect]]
        script = /discover/nobackup/projects/ghilis/smahanam/PR79_E2E/scratch/202601/ghis2s_log.sh
        platform = localhost-ghi
  
    [[stop_log_monitor]]
        platform = localhost-ghi
        script = """
            cylc stop $CYLC_WORKFLOW_ID --now
        """
  
    [[africa_1--lisda_africa_1_run]]
        script = /discover/nobackup/projects/ghilis/smahanam/PR79_E2E/scratch/202601/lis_darun/africa_1/lisda_africa_1_run.sh
        [[[directives]]]
            --account=s1189
            --time=300
            --constraint=mil
            --nodes=1
            --ntasks-per-node=126
