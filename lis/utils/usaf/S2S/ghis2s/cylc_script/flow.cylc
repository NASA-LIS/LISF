#!jinja2
# S2S Forecast Workflow
  
[meta]
    title = S2S Forecast Workflow
    description = S2S Forecast Initialized on 2026-01
  
[scheduler]
    UTC mode = True
    cycle point format = %Y%m%dT%H%M
  
[scheduling]
    initial cycle point = now
    final cycle point = +P2D
    runahead limit = P2D
  
    [[xtriggers]]
